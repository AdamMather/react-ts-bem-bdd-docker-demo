{
  "name": "react-contact-search",
  "private": true,
  "version": "0.0.0",
  "type": "commonjs",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:gherkin": "start-server-and-test \"vite --host 127.0.0.1 --port 3000 --strictPort\" http://127.0.0.1:3000 \"cucumber-js tests/features --require tests/step_definitions/**/*.js --format progress\"",
    "test:gherkin:kennel-boarding": "start-server-and-test \"vite --host 127.0.0.1 --port 3000 --strictPort\" http://127.0.0.1:3000 \"cucumber-js tests/features/kennel-boarding.feature --require tests/step_definitions/**/*.js --format progress\"",
    "test:playwright": "start-server-and-test \"vite --host 127.0.0.1 --port 3000 --strictPort\" http://127.0.0.1:3000 \"playwright test --reporter=line\"",
    "test:playwright:ui": "start-server-and-test \"vite --host 127.0.0.1 --port 3000 --strictPort\" http://127.0.0.1:3000 \"playwright test --ui\"",
    "test:playwright:update-snapshots": "start-server-and-test \"vite --host 127.0.0.1 --port 3000 --strictPort\" http://127.0.0.1:3000 \"playwright test tests/e2e/visual.spec.js --update-snapshots\"",
    "sonar:scan": "bash ./scripts/run-sonar-scan.sh",
    "ci-local": "npm ci && npm run lint && npm run test:unit:coverage && npm run test:gherkin && npm run test:playwright && npm run sonar:scan",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "formik": "^2.4.6",
    "pg": "^8.11.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.23.1",
    "start-server-and-test": "^2.1.5",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@cucumber/cucumber": "^12.6.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.14.5",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.7.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "jsdom": "^29.0.1",
    "playwright": "^1.58.2",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
